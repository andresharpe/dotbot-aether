{
  "name": "console",
  "type": "console",
  "version": "1.0.0",
  "description": "Control surface conduit — Stream Deck integration",
  "module": "src/DotBot.Aether.Console/DotBot.Aether.Console.psd1",
  "repo": "https://github.com/andresharpe/dotbot-aether-console",
  "capabilities": ["button-state", "button-icon", "strip-icon", "deck-state", "dotbot-state", "hue-bridge"],
  "discovery": "local",
  "protocol": "http-sidecar+websocket",
  "platforms": ["windows"],
  "events": ["task.started", "task.completed", "task.failed", "process.started", "process.stopped", "workflow.completed", "button.pressed"],
  "settings": {
    "sidecar_port": { "type": "integer", "default": 7331 },
    "poll_interval_ms": { "type": "integer", "default": 500 },
    "auto_reconnect": { "type": "boolean", "default": true }
  }
}